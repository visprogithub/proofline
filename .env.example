# Public browser configuration from Supabase Project Settings > API.
# Do not put the GitHub OAuth client secret in this file or any VITE_ variable.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Server-only Vercel Function variables. Never prefix these with VITE_ and never commit real values.
HF_TOKEN=hf_your_server_only_token
HF_MODEL=provider/model-name
# Optional; defaults to https://router.huggingface.co/v1
HF_ENDPOINT=https://router.huggingface.co/v1
RATE_LIMIT_SALT=replace_with_a_long_random_server_only_value

# Optional hosted-skeptic budgets and cutoffs. The evidence skeptic and the interpreted
# integrity pass share one budget, so a thorough review can spend several dozen calls.
# AI_PER_CLIENT_DAILY_LIMIT is the anti-abuse lever (per salted connection, per UTC day);
# the global values are the backstop. Limits are best-effort per warm instance.
AI_PER_CLIENT_DAILY_LIMIT=250
AI_GLOBAL_DAILY_LIMIT=5000
AI_GLOBAL_DAILY_TOKEN_LIMIT=20000000
AI_PROVIDER_TIMEOUT_MS=20000
AI_MAX_OUTPUT_TOKENS=320
