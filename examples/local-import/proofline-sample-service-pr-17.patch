@@ -0,0 +1,8 @@
+const MAX_IMPORT_BYTES = 5 * 1024 * 1024
+
+// REQ-103: Reject oversized imports.
+export function validateImportSize(file: File): void {
+  if (file.size > MAX_IMPORT_BYTES) {
+    throw new Error('This file exceeds the 5 MB local import limit.')
+  }
+}
